bash -c 'set -e;ACME="/data/traefik/dynamic/acme.json";SSL="/data/ssl";DOVECOT_SSL="/etc/dovecot/conf.d/10-ssl.conf";HARAKA_SMTP_TLS="/opt/haraka-smtp/config/tls";HARAKA_SUB_TLS="/opt/haraka-submission/config/tls";command -v jq >/dev/null 2>&1 || apt-get update -qq && apt-get install -y jq;mkdir -p "$SSL" "$HARAKA_SMTP_TLS" "$HARAKA_SUB_TLS";DOMAINS=$(jq -r ".letsencrypt.Certificates[] | select(.domain.main | startswith(\"mail.\")) | .domain.main" "$ACME");[ -z "$DOMAINS" ] && echo "No mail.* certs found" && exit 1;S=0;TOTAL=$(echo "$DOMAINS" | wc -w);printf "ssl = required\nssl_server_cert_file = /etc/ssl/server-combined.crt\nssl_server_key_file = /etc/ssl/server.key\nssl_server_dh_file = /etc/ssl/dh4096.pem\nssl_min_protocol = TLSv1.1\nssl_cipher_list = ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384:DHE-RSA-CHACHA20-POLY1305:ECDHE-ECDSA-AES128-SHA256:ECDHE-RSA-AES128-SHA256:ECDHE-ECDSA-AES128-SHA:ECDHE-RSA-AES128-SHA:ECDHE-ECDSA-AES256-SHA384:ECDHE-RSA-AES256-SHA384:ECDHE-ECDSA-AES256-SHA:ECDHE-RSA-AES256-SHA:DHE-RSA-AES128-SHA256:DHE-RSA-AES256-SHA256:AES128-GCM-SHA256:AES256-GCM-SHA384:AES128-SHA256:AES256-SHA256:AES128-SHA:AES256-SHA:DES-CBC3-SHA\nssl_server_prefer_ciphers = server\n" > "$DOVECOT_SSL";for D in $DOMAINS; do CE=$(jq -c --arg d "$D" ".letsencrypt.Certificates[] | select(.domain.main==\$d)" "$ACME");mkdir -p "$SSL/$D";echo "$CE" | jq -r ".certificate" | base64 -d | awk "/BEGIN CERTIFICATE/{i++}i==1" > "$SSL/$D/server.crt";echo "$CE" | jq -r ".certificate" | base64 -d | awk "/BEGIN CERTIFICATE/{i++}i>1" > "$SSL/$D/ca.crt";echo "$CE" | jq -r ".key" | base64 -d > "$SSL/$D/server.key";cat "$SSL/$D/server.crt" "$SSL/$D/ca.crt" > "$SSL/$D/server-combined.crt";chmod 600 "$SSL/$D/"*;printf "local_name %s {\n  ssl_server_cert_file = %s/%s/server-combined.crt\n  ssl_server_key_file = %s/%s/server.key\n}\n" "$D" "$SSL" "$D" "$SSL" "$D" >> "$DOVECOT_SSL";ln -sf "$SSL/$D/server-combined.crt" "$HARAKA_SMTP_TLS/$D.crt";ln -sf "$SSL/$D/server.key" "$HARAKA_SMTP_TLS/$D.key";ln -sf "$SSL/$D/server-combined.crt" "$HARAKA_SUB_TLS/$D.crt";ln -sf "$SSL/$D/server.key" "$HARAKA_SUB_TLS/$D.key";echo "OK: $D";S=$((S+1));done;LAST=$(echo "$DOMAINS" | tr " " "\n" | tail -1);cat "$SSL/$LAST/server-combined.crt" > /etc/ssl/server-combined.crt && cp "$SSL/$LAST/server.key" /etc/ssl/server.key && cat "$SSL/$LAST/server-combined.crt" > "$SSL/server.crt" && cp "$SSL/$LAST/server.key" "$SSL/server.key" && echo "Default cert set to: $LAST";doveconf -n > /dev/null 2>&1 && dovecot reload && echo "Dovecot reloaded" || echo "ERROR: dovecot config invalid - check $DOVECOT_SSL";s6-svc -d /run/s6/services/haraka-smtp && sleep 3 && s6-svc -u /run/s6/services/haraka-smtp && echo "haraka-smtp restarted";s6-svc -d /run/s6/services/haraka-submission && sleep 3 && s6-svc -u /run/s6/services/haraka-submission && echo "haraka-submission restarted";echo "Done: $S/$TOTAL domain(s) at $(date)";curl -sS -o /usr/local/share/ca-certificates/isrg-root-yr.crt https://letsencrypt.org/certs/gen-y/root-yr.pem;curl -sS -o /usr/local/share/ca-certificates/isrg-root-ye.crt https://letsencrypt.org/certs/gen-y/root-ye.pem;curl -sS -o /usr/local/share/ca-certificates/letsencrypt-r13.crt https://letsencrypt.org/certs/2024/r13.pem;update-ca-certificates'
